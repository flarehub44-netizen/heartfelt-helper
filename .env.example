VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
# Public key is safe for the client; private key must only live in Edge secrets.
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"

# Edge Function secrets (Dashboard → Edge Functions → Secrets, or `supabase secrets set`):
#   VAPID_PUBLIC_KEY=...   (same as VITE_VAPID_PUBLIC_KEY)
#   VAPID_PRIVATE_KEY=...
#   VAPID_SUBJECT=mailto:suporte@flare.app
#   SYNCPAY_CLIENT_ID=...
#   SYNCPAY_CLIENT_SECRET=...
#   SYNCPAY_WEBHOOK_SECRET=...
# Cash-out (saque Pix) exige liberação na conta SyncPay + IP autorizado.
# A edge request-withdrawal chama POST /api/partner/v1/cash-out.
